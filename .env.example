# =============================================================================
# DATABASE — Neon PostgreSQL
# =============================================================================
# DATABASE_URL: cadena de conexión POOLED (pgBouncer). Úsala en runtime.
# Obtén ambas desde el dashboard de Neon > tu proyecto > Connection string.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require&pgbouncer=true"

# DIRECT_URL: cadena DIRECTA (sin pooler). Úsala solo para prisma migrate.
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# =============================================================================
# JWT
# =============================================================================
# Genera valores seguros con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="cambia_esto_por_un_secreto_seguro_de_al_menos_64_chars"
JWT_REFRESH_SECRET="cambia_esto_por_otro_secreto_seguro_diferente_al_anterior"

# =============================================================================
# EMAIL — Resend  (https://resend.com)
# =============================================================================
# 1. Crea cuenta en resend.com (plan gratuito: 3 000 emails/mes)
# 2. Ve a API Keys → Create API Key → copia el valor aquí
# 3. Para desarrollo puedes usar el dominio de prueba: from = "onboarding@resend.dev"
#    Para producción: verifica tu dominio en Resend → Domains y usa tu propio dominio.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Dirección "From" de los correos. En desarrollo usa "onboarding@resend.dev".
# En producción usa algo como "noreply@tudominio.com" (dominio verificado en Resend).
FROM_EMAIL="Simulador EDD <onboarding@resend.dev>"

# =============================================================================
# APP
# =============================================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
